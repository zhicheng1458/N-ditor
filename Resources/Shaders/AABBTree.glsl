////////////////////////////////////////
// AABBTree.glsl
////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////

#ifdef VERTEX_SHADER

layout(location=0) in vec2 Position;

uniform mat4 ViewProjMtx=mat4(1);

////////////////////////////////////////
// Vertex shader
////////////////////////////////////////

void main()
{
	gl_Position= ViewProjMtx * vec4(Position,0.0,1.0);
}

#endif

////////////////////////////////////////////////////////////////////////////////

#ifdef FRAGMENT_SHADER

out vec4 finalColor;

////////////////////////////////////////
// Fragment shader
////////////////////////////////////////
void main()
{
	finalColor = vec4(0.0, 0.0, 0.0, 1.0);
}

#endif

////////////////////////////////////////////////////////////////////////////////
